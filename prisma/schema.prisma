// ===== Prisma schema — Best Medical (Fase 1) =====
// PostgreSQL. Valores monetários em centavos (Int). Datas em DateTime (@db.Date).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  admin
  operador
  visualizador
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  // Login por usuário (nome+sobrenome juntos, minúsculo, sem espaços). Único.
  usuario   String   @unique
  email     String   @unique
  senhaHash String   @map("senha_hash")
  perfil    Perfil   @default(operador)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orcamentos Orcamento[]
  propostas  Proposta[]
  followUps  FollowUp[]

  @@map("usuarios")
}

model Cliente {
  id          String   @id @default(uuid())
  cnpj        String?  @unique
  nome        String
  cep         String?
  endereco    String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?  @db.Char(2)
  pais        String   @default("Brasil")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contatos   Contato[]
  orcamentos Orcamento[]
  propostas  Proposta[]

  @@map("clientes")
}

model Contato {
  id        String   @id @default(uuid())
  clienteId String   @map("cliente_id")
  nome      String
  setor     String?
  telefone  String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cliente    Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  orcamentos Orcamento[]
  propostas  Proposta[]

  @@map("contatos")
}

// ===== CRM — agenda de contatos independente =====
// Lista de contatos importada do celular (vCard/CSV) ou cadastrada à mão.
// Não tem relação com Cliente/Orçamento: é uma agenda comercial própria.
model CrmContato {
  id              String   @id @default(uuid())
  nome            String
  empresa         String?
  telefone        String?
  telefonePessoal String?  @map("telefone_pessoal")
  email           String?
  // Relacionamento: 1 (sem relacionamento) a 5 (excelente). Default 1.
  relacionamento  Int      @default(1)
  // Pessoal: marca contatos pessoais (não profissionais). Continua no banco,
  // mas pode ser ocultado por filtro na tela do CRM.
  pessoal         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("crm_contatos")
}

model Orcamento {
  id     String   @id @default(uuid())
  numero String   @unique
  data   DateTime @db.Date

  clienteId String  @map("cliente_id")
  contatoId String? @map("contato_id")
  criadoPor String? @map("criado_por")

  // Snapshot (preenchido na emissão) — preserva histórico
  clienteNomeSnap String? @map("cliente_nome_snap")
  clienteCnpjSnap String? @map("cliente_cnpj_snap")
  solicitanteSnap String? @map("solicitante_snap")
  setorSnap       String? @map("setor_snap")
  telefoneSnap    String? @map("telefone_snap")
  emailSnap       String? @map("email_snap")

  // Dados técnicos
  modalidade      String?
  marca           String?
  marcaOutras     String? @map("marca_outras")
  modelo          String?
  numeroSerie     String? @map("numero_serie")
  descricaoVisita String? @map("descricao_visita")

  // Resumo financeiro
  descontoPercent  Float @default(0) @map("desconto_percent")
  numParcelas      Int   @default(1) @map("num_parcelas")
  subtotalCentavos Int   @default(0) @map("subtotal_centavos")
  descontoCentavos Int   @default(0) @map("desconto_centavos")
  totalCentavos    Int   @default(0) @map("total_centavos")

  // Finalização
  observacoes String?
  textoFinal  String? @map("texto_final")

  // Status (espelha a página de Controle)
  statusEnviado            Boolean   @default(false) @map("status_enviado")
  statusAprovado           Boolean   @default(false) @map("status_aprovado")
  statusRealizado          Boolean   @default(false) @map("status_realizado")
  statusAguardandoPeca     Boolean   @default(false) @map("status_aguardando_peca")
  statusOrdemServico       Boolean   @default(false) @map("status_ordem_servico")
  statusPagamentoRealizado Boolean   @default(false) @map("status_pagamento_realizado")
  statusReprovado          Boolean   @default(false) @map("status_reprovado")
  enviadoEm                DateTime? @map("enviado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cliente      Cliente         @relation(fields: [clienteId], references: [id])
  contato      Contato?        @relation(fields: [contatoId], references: [id])
  criador      Usuario?        @relation(fields: [criadoPor], references: [id])
  itens        ItemOrcamento[]
  parcelas     Parcela[]
  ordemServico OrdemServico?
  followUps    FollowUp[]

  @@index([data])
  @@index([clienteId])
  @@map("orcamentos")
}

model ItemOrcamento {
  id                String @id @default(uuid())
  orcamentoId       String @map("orcamento_id")
  ordem             Int    @default(0)
  codigo            String @default("")
  descricao         String @default("")
  quantidade        Int    @default(1)
  valorItemCentavos Int    @default(0) @map("valor_item_centavos")

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("itens_orcamento")
}

model Parcela {
  id             String    @id @default(uuid())
  orcamentoId    String    @map("orcamento_id")
  numero         Int
  dataVencimento DateTime? @map("data_vencimento") @db.Date
  valorCentavos  Int       @default(0) @map("valor_centavos")
  pago           Boolean   @default(false)
  pagoEm         DateTime? @map("pago_em") @db.Date

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("parcelas")
}

model OrdemServico {
  id          String   @id @default(uuid())
  numero      String   @unique // OS-2026-0001
  orcamentoId String   @unique @map("orcamento_id") // 1 OS por orçamento
  data        DateTime @db.Date

  // Snapshot de cliente/solicitante/equipamento (copiado do orçamento na criação)
  clienteNomeSnap String? @map("cliente_nome_snap")
  clienteCnpjSnap String? @map("cliente_cnpj_snap")
  // Endereço copiado do cadastro do cliente no momento da criação
  cep             String?
  endereco        String?
  enderecoNumero  String? @map("endereco_numero")
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  pais            String? @default("Brasil")
  solicitanteSnap String? @map("solicitante_snap")
  setorSnap       String? @map("setor_snap")
  telefoneSnap    String? @map("telefone_snap")
  emailSnap       String? @map("email_snap")

  // Equipamento
  modalidade      String?
  marca           String?
  marcaOutras     String? @map("marca_outras")
  modelo          String?
  numeroSerie     String? @map("numero_serie")
  descricaoVisita String? @map("descricao_visita")

  // Campos próprios da OS
  descricaoServico String? @map("descricao_servico") // caixa de texto "descrição do serviço"
  observacoes      String?

  // Assinaturas (data URL base64 PNG do canvas — pode ficar grande, use @db.Text)
  assinaturaCliente String? @map("assinatura_cliente") @db.Text
  assinaturaTecnico String? @map("assinatura_tecnico") @db.Text

  statusEnviado Boolean   @default(false) @map("status_enviado")
  enviadoEm     DateTime? @map("enviado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  itens     ItemOS[]
  fotos     FotoOS[]

  @@map("ordens_servico")
}

model ItemOS {
  id         String  @id @default(uuid())
  ordemId    String  @map("ordem_id")
  ordem      Int     @default(0) // posição
  codigo     String  @default("")
  descricao  String  @default("") // "item"
  quantidade Int     @default(1)
  realizado  Boolean @default(false) // checkbox "trabalho realizado"
  detalhes   String  @default("") // coluna "Detalhes" (campo preenchível)

  os OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)

  @@index([ordemId])
  @@map("itens_os")
}

model FotoOS {
  id      String @id @default(uuid())
  ordemId String @map("ordem_id")
  ordem   Int    @default(0)
  // Imagem em data URL base64 (jpeg/png). Use @db.Text.
  dataUrl String @map("data_url") @db.Text
  legenda String @default("")

  os OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)

  @@index([ordemId])
  @@map("fotos_os")
}

// ===== Proposta de Contrato =====
// Espelha o Orcamento: snapshots de cliente/solicitante, resumo financeiro em
// centavos e back-relations opcionais para Cliente/Contato/Usuario. Os
// equipamentos cobertos ficam em ItemPropostaEquip (1 linha = 1 equipamento,
// com o "Valor do Contrato" mensal próprio).
model Proposta {
  id     String   @id @default(uuid())
  numero String   @unique // PC-2026-0001
  data   DateTime @db.Date

  clienteId String  @map("cliente_id")
  contatoId String? @map("contato_id")
  criadoPor String? @map("criado_por")

  // Snapshot (preenchido na emissão) — preserva histórico
  clienteNomeSnap String? @map("cliente_nome_snap")
  clienteCnpjSnap String? @map("cliente_cnpj_snap")
  solicitanteSnap String? @map("solicitante_snap")
  setorSnap       String? @map("setor_snap")
  telefoneSnap    String? @map("telefone_snap")
  emailSnap       String? @map("email_snap")

  // Modalidade do contrato
  tipoContrato String @map("tipo_contrato") // "Suporte Remoto" | "Mão de Obra - Regular" | "Mão de Obra - Especial"

  // Condições do contrato (texto editável) + snapshot do texto padrão vigente
  // na criação (usado como base estável para o diff de customizações).
  condicoesContrato   String @default("") @map("condicoes_contrato") @db.Text
  condicoesPadraoSnap String @default("") @map("condicoes_padrao_snap") @db.Text
  // Observações internas: recebe automaticamente o bloco de customizações
  // (entre marcadores) e preserva anotações manuais. Não aparece no PDF.
  observacoesInternas String @default("") @map("observacoes_internas") @db.Text

  // Texto final (rodapé do PDF)
  textoFinal String? @map("texto_final") @db.Text

  // Resumo financeiro (mensal)
  descontoPercent  Float @default(0) @map("desconto_percent")
  subtotalCentavos Int   @default(0) @map("subtotal_centavos")
  descontoCentavos Int   @default(0) @map("desconto_centavos")
  totalCentavos    Int   @default(0) @map("total_centavos")

  // Status / envio (mesmos status de controle do orçamento)
  statusEnviado            Boolean   @default(false) @map("status_enviado")
  statusAprovado           Boolean   @default(false) @map("status_aprovado")
  statusRealizado          Boolean   @default(false) @map("status_realizado")
  statusAguardandoPeca     Boolean   @default(false) @map("status_aguardando_peca")
  statusOrdemServico       Boolean   @default(false) @map("status_ordem_servico")
  statusPagamentoRealizado Boolean   @default(false) @map("status_pagamento_realizado")
  // Status específicos de Proposta de Contrato (PC)
  statusAssinado           Boolean   @default(false) @map("status_assinado")
  statusVigente            Boolean   @default(false) @map("status_vigente")
  statusReprovado          Boolean   @default(false) @map("status_reprovado")
  enviadoEm                DateTime? @map("enviado_em")

  // Contrato assinado (PDF) carregado pelo usuário, armazenado em base64.
  contratoAssinadoArquivo String?   @map("contrato_assinado_arquivo") @db.Text
  contratoAssinadoNome    String?   @map("contrato_assinado_nome")
  contratoAssinadoEm      DateTime? @map("contrato_assinado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cliente      Cliente             @relation(fields: [clienteId], references: [id])
  contato      Contato?            @relation(fields: [contatoId], references: [id])
  criador      Usuario?            @relation(fields: [criadoPor], references: [id])
  equipamentos ItemPropostaEquip[]
  contrato     Contrato?
  followUps    FollowUp[]

  @@index([data])
  @@index([clienteId])
  @@map("propostas")
}

// Registro de follow-up (acompanhamento comercial). Vinculado a um
// orçamento OU a uma proposta. Guarda quem escreveu e quando.
model FollowUp {
  id          String   @id @default(uuid())
  orcamentoId String?  @map("orcamento_id")
  propostaId  String?  @map("proposta_id")
  autorId     String?  @map("autor_id")
  autorNome   String   @map("autor_nome")
  texto       String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  orcamento Orcamento? @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  proposta  Proposta?  @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  autor     Usuario?   @relation(fields: [autorId], references: [id])

  @@index([orcamentoId])
  @@index([propostaId])
  @@map("follow_ups")
}

// ===== Contrato =====
// Documento de contrato gerado a partir de uma Proposta aprovada (1 contrato
// por proposta). Espelha o fluxo da Ordem de Serviço (gerada do orçamento):
// guarda um snapshot do corpo padrão gerado a partir do template e o corpo
// efetivamente customizado pelo usuário. As customizações (diff linha a linha
// do corpo customizado x padrão) são replicadas nas Observações Internas da
// PROPOSTA de origem, no mesmo formato de marcadores usado no resto do sistema.
model Contrato {
  id         String   @id @default(uuid())
  numero     String   @unique // CT-2026-0001 (derivado do número da proposta)
  propostaId String   @unique @map("proposta_id") // 1 contrato por proposta
  data       DateTime @db.Date

  // Corpo do contrato (cláusulas) em texto, uma cláusula/linha por parágrafo.
  // conteudoPadraoSnap = versão gerada do template na criação (base do diff).
  // conteudoCustomizado = versão editada pelo usuário (renderizada no PDF).
  conteudoPadraoSnap  String @default("") @map("conteudo_padrao_snap") @db.Text
  conteudoCustomizado String @default("") @map("conteudo_customizado") @db.Text

  dataGeracao DateTime @default(now()) @map("data_geracao")

  statusEnviado Boolean   @default(false) @map("status_enviado")
  enviadoEm     DateTime? @map("enviado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@map("contratos")
}

model ItemPropostaEquip {
  id            String @id @default(uuid())
  propostaId    String @map("proposta_id")
  ordem         Int    @default(0)
  modalidade    String @default("")
  marca         String @default("")
  marcaOutras   String @default("") @map("marca_outras")
  modelo        String @default("")
  numeroSerie   String @default("") @map("numero_serie")
  // "Valor do Contrato" (mensal) da linha, em centavos
  valorCentavos Int    @default(0) @map("valor_centavos")

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@index([propostaId])
  @@map("itens_proposta_equip")
}
