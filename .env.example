# ===== Variáveis de ambiente — Best Medical Backend =====

# String de conexão do PostgreSQL
# Local (Docker/instalação local):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bestmedical?schema=public"
# No Render, use a "Internal Database URL" fornecida pelo PostgreSQL gerenciado.

# Segredo do JWT (troque por um valor longo e aleatório em produção)
JWT_SECRET="troque-este-segredo-por-uma-string-longa-e-aleatoria"
# Validade do token de acesso
JWT_EXPIRES_IN="7d"

# Porta HTTP (Render injeta PORT automaticamente)
PORT=3000

# Origens permitidas para CORS (separadas por vírgula).
# Inclua a URL do seu front-end. Use * para liberar geral em desenvolvimento.
CORS_ORIGIN="http://localhost:5173,https://bestmedical.pplx.app"

# Usuário administrador inicial criado pelo seed
SEED_ADMIN_EMAIL="admin@bestmedical.com.br"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NOME="Administrador"
